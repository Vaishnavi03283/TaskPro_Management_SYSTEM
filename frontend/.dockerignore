# ========================================
# DOCKERIGNORE - FRONTEND
# ========================================
# Exclude unnecessary files from Docker build context

# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist
build

# Environment files
.env
.env.local
.env.*.local

# Development files
.git
.gitignore
README.md
Dockerfile
.dockerignore
nginx.conf

# IDE files
.vscode
.idea
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
logs
*.log

# Coverage reports
coverage
.nyc_output

# ESLint cache
.eslintcache

# Vite cache
.vite

# Temporary files
*.tmp
*.temp
